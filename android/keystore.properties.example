# Release imzası için bu dosyayı 'keystore.properties' adıyla kopyalayıp doldurun.
# keystore.properties git'e girmez (bkz. android/.gitignore).
#
# Anahtar üretmek için:
#   keytool -genkeypair -v -keystore cengelbulmaca.keystore -alias cengelbulmaca \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile, android/ klasörüne göre görecelidir.
storeFile=cengelbulmaca.keystore
storePassword=DEGISTIR
keyAlias=cengelbulmaca
keyPassword=DEGISTIR
